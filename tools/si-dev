#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "${SOURCE}" ]]; do
  DIR="$(cd -P "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
ROOT="$(cd "$(dirname "${SOURCE}")/.." && pwd)"
BIN="${ROOT}/.artifacts/si"
TARGET_DIR="${ROOT}/.artifacts/cargo-target"

needs_build=0
if [[ ! -x "${BIN}" ]]; then
  needs_build=1
else
  if find "${ROOT}/rust" -name '*.rs' -newer "${BIN}" -print -quit | grep -q .; then
    needs_build=1
  fi
  if [[ "${ROOT}/Cargo.toml" -nt "${BIN}" || "${ROOT}/Cargo.lock" -nt "${BIN}" || "${ROOT}/rust/crates/si-cli/Cargo.toml" -nt "${BIN}" ]]; then
    needs_build=1
  fi
fi

if [[ ${needs_build} -eq 1 ]]; then
  mkdir -p "${ROOT}/.artifacts"
  (cd "${ROOT}" && cargo build --release --locked -p si-rs-cli --bin si-rs --target-dir "${TARGET_DIR}")
  cp "${TARGET_DIR}/release/si-rs" "${BIN}"
fi

exec "${BIN}" "$@"
